# Generated by `terraform apply` (cicd/) from pipeline.yml.tftpl with this project's WIF values.
# Not committed in the template — each clone generates its own. Do not edit by hand; re-run terraform.
name: CI/CD

on:
  pull_request:
    branches: [main]

permissions:
  contents: read
  id-token: write

jobs:
  ci:
    uses: ./.github/workflows/ci.yml

  cd:
    needs: ci
    uses: ./.github/workflows/cd.yml
    permissions:
      contents: read
      id-token: write
    with:
      project_id: ${project_id}
      region: ${region}
      agent_dir: agents/brand-guidelines-checker
      workload_identity_provider: ${workload_identity_provider}
      service_account: ${service_account}
